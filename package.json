{
  "name": "marp-native-pptx",
  "version": "0.1.0",
  "description": "Native Marp -> editable PowerPoint generator. Reads the rendered DOM and emits native pptx shapes (no PDF/LibreOffice round-trip, no text fragmentation).",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "marp-native-pptx": "./dist/cli.js",
    "marp-native-pptx-validate": "./dist/validate-cli.js"
  },
  "main": "./dist/convert.js",
  "exports": {
    ".": "./dist/convert.js",
    "./validate": "./dist/validate.js",
    "./blocks": "./dist/blocks-convert.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "vitest run --config vitest.visual.config.ts",
    "test:visual:update": "UPDATE_GOLDENS=1 vitest run --config vitest.visual.config.ts",
    "cli": "tsx src/cli.ts",
    "validate": "tsx src/validate-cli.ts"
  },
  "dependencies": {
    "@marp-team/marp-core": "^4.0.0",
    "fast-xml-parser": "^4.4.0",
    "jszip": "^3.10.0",
    "pptxgenjs": "^3.12.0",
    "puppeteer-core": "^23.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
